# ============================================================================
# CONFIGURAÇÃO DO MERCADO (white-label)
# Copie para .env.local (dev) ou configure na Vercel (Settings → Env Vars).
# Tudo abaixo é opcional: sem nada definido, o site sobe com os dados de demo.
# Variáveis NEXT_PUBLIC_ aparecem no navegador e são aplicadas no build/deploy.
# ============================================================================

# --- IA do assistente (servidor) ---
# Obtenha grátis em https://build.nvidia.com → API Keys
NVIDIA_API_KEY=nvapi-...

# --- Identidade do assistente (navegador) ---
NEXT_PUBLIC_ASSISTANT_NAME=Dinizinho
NEXT_PUBLIC_ASSISTANT_ROLE=seu assistente virtual

# --- Identidade do mercado (navegador) ---
NEXT_PUBLIC_MARKET_NAME=DINIZ Comercial e Frios
NEXT_PUBLIC_MARKET_SHORT_NAME=DINIZ
NEXT_PUBLIC_MARKET_TAGLINE=Comercial e Frios
NEXT_PUBLIC_MARKET_DESCRIPTION=frios selecionados, produtos frescos e o melhor preço do bairro
NEXT_PUBLIC_MARKET_CITY=Lagoa Nova, Irecê – BA
NEXT_PUBLIC_MARKET_ADDRESS=Lagoa Nova, Irecê – BA
NEXT_PUBLIC_MARKET_CEP=44900-000
NEXT_PUBLIC_MARKET_HOURS=Seg a Sáb · fecha às 20h

# Opcionais (deixe em branco para ocultar o elemento na tela)
NEXT_PUBLIC_MARKET_RATING=4,6 ★ no Google
NEXT_PUBLIC_MARKET_WHATSAPP=5574999995365
NEXT_PUBLIC_MARKET_PHONE=(74) 99999-5365
NEXT_PUBLIC_MARKET_PAYMENTS=Visa,Mastercard,Elo,Hipercard,Pix

# Crédito do desenvolvedor (rodapé) — deixe em branco para esconder
NEXT_PUBLIC_DEVELOPER_NAME=Ítalo Lima
NEXT_PUBLIC_DEVELOPER_URL=https://italolima.com.br

# --- Relay WhatsApp (atendimento humano) ---
# O relay é um servidor standalone que mantém a conexão Baileys viva.
# Rode a pasta relay/ em host persistente (Railway, Fly.io, Docker).
# A URL do relay é configurada aqui (Next.js → Vercel) como env de servidor.
# RELAY_URL=https://seu-relay.up.railway.app
# RELAY_AUTH_TOKEN=change-me

# --- Integração de produtos (servidor) ---
# Sem PRODUCTS_API_URL, o site usa o catálogo de demonstração embutido.
# Com a URL definida, o site consome a API do mercado (JSON: array de produtos
# ou { products: [...] }). Em qualquer erro, cai no catálogo de demo.
# PRODUCTS_API_URL=https://api.seu-mercado.com.br/produtos
# PRODUCTS_API_KEY=
