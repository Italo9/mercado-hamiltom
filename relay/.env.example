# ============================================================================
# RELAY WHATSAPP — variáveis do servidor standalone
# Configure no Railway (Variables) ou no .env do Docker.
# ============================================================================

# Ativa a conexão com o WhatsApp (Baileys). Sem isso, o relay responde mas
# sempre retorna enabled:false (atendimento humano indisponível).
WHATSAPP_ENABLED=true

# Número do atendente (só dígitos, com DDI 55).
WHATSAPP_ATTENDANT_NUMBER=5574999690535

# Token compartilhado entre o Next.js (Vercel) e o relay pra autenticar as
# chamadas. Deve ser o mesmo valor nos dois lados.
RELAY_AUTH_TOKEN=change-me

# Diretório da sessão do WhatsApp (persiste o pareamento via volume).
WHATSAPP_AUTH_DIR=./.whatsapp-auth

# Tempo máximo sem atividade do cliente antes de encerrar a sessão (ms).
HUMAN_TIMEOUT_MS=180000
